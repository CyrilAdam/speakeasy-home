{
  "name": "speakeasy-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "seed": "tsx src/db/seed.ts",
    "seed:reset": "tsx src/db/seed.ts --reset",
    "test": "node --import tsx/esm --test --test-reporter spec tests/bottles.test.ts tests/cocktails.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.12.0",
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
